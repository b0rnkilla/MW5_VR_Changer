<Window x:Class="MW5_VR_Changer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MW5_VR_Changer"
        mc:Ignorable="d"
        Title="MW5 VR Changer" Height="266" Width="360">
    <Grid Margin="12" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Grid.Resources>
            <Style x:Key="PathButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="110" />
                <Setter Property="Height" Value="26" />
                <Setter Property="Margin" Value="0,4,0,4" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Background" Value="IndianRed" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="26" />
                <Setter Property="Margin" Value="0,12,0,4" />
                <Setter Property="Padding" Value="10,4" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="70" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="110" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Game" />
        <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding BrowseGameCommand}" ToolTip="{Binding GamePath}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PathButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasGamePath}" Value="True">
                            <Setter Property="Background" Value="ForestGreen" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="AppData" />
        <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseAppDataCommand}" ToolTip="{Binding AppDataPath}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PathButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAppDataPath}" Value="True">
                            <Setter Property="Background" Value="ForestGreen" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Auto Detect" Command="{Binding AutoDetectPathsCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,12,8,4" />
        <Button Grid.Row="2" Grid.Column="2" Content="Create Backup" Command="{Binding CreateBackupCommand}" Style="{StaticResource ActionButtonStyle}" />

        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="Mode" Margin="0,0,8,0" />
                <ToggleButton Width="70" Height="26" IsEnabled="{Binding IsSwitchEnabled}" IsChecked="{Binding IsVrMode, Mode=TwoWay}">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="NonVR" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVrMode}" Value="True">
                                        <Setter Property="Text" Value="VR" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </ToggleButton>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="Backup:" HorizontalAlignment="Center" Margin="0,0,0,2" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Text="VR" Margin="0,0,4,0" />
                    <CheckBox Margin="0,0,12,0" IsChecked="{Binding VrBackupComplete}" IsEnabled="False" VerticalAlignment="Center" HorizontalAlignment="Center" />

                    <TextBlock VerticalAlignment="Center" Text="NonVR" Margin="0,0,4,0" />
                    <CheckBox IsChecked="{Binding NonVrBackupComplete}" IsEnabled="False" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,5,0,20" Padding="8" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock TextWrapping="Wrap" Text="{Binding StatusMessage}" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
